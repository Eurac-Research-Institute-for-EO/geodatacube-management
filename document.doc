    <div class="WordSection3">
      <p class="zzSTDTitle1">Best Practice for OGC GeoDataCube Management</p>
      <div><a name="_scope" id="_scope"></a>
        <h1>1.<span style="mso-tab-count:1">&#xA0; </span>Scope</h1>
        <div class="Note"><a name="_8bce853b-9aa0-47bc-8eb0-c70f277441a8" id="_8bce853b-9aa0-47bc-8eb0-c70f277441a8"></a>
